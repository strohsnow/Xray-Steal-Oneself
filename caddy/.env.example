# https://github.com/CaddyBuilds/caddy-cloudflare?tab=readme-ov-file#configuration
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# Consistent with Xray config
REALITY_DOMAIN=reality
BASE_DOMAIN=domain.tld

# openssl rand -hex 8
SUB_PATH=your_sub_path

# Allowed HWIDs separated by `|`
# If empty, all HWIDs are allowed
ALLOWED_HWID="hwid_1|hwid_2|hwid_3"

# https://utils.docs.rw/happ-rb
ROUTING_HEADER=happ:

# openssl rand -hex 32
MINIO_ROOT_PASSWORD=your_minio_root_password
MINIO_ROOT_USER=root
